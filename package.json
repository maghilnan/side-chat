    "test:e2e:headed": "npx playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "jest-chrome": "^0.8.0",
    "jsdom": "^26.0.0",
    "serve": "^14.2.0",
    "vitest": "^3.0.0"
  }
}
